# scripts/.env.example
# Copy jadi .env.migration, isi nilai sebenarnya, JANGAN commit file hasilnya ke git.

# Project Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Project Settings → API → service_role key (BUKAN anon key — ini bypass RLS,
# sangat sensitif, hanya untuk skrip migrasi sekali-jalan ini)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
